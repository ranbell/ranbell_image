# Copy this file to docker-compose.override.yml and edit it for your environment.
# docker compose automatically merges docker-compose.yml and docker-compose.override.yml.
#
# [Source images — multiple folders]
#   Mount directories as subdirectories of /mnt/image/source/.
#   The subdirectory name becomes the folder label in the app.
#
# [Generated images]
#   Images generated by ComfyUI are saved to /mnt/image/generated.
#   Mount a writable directory here.

services:
  backend:
    environment:
      # API authentication token — must match the token stored in the frontend localStorage
      API_TOKEN: RANBELL_IMAGE_API_TOKEN
      # Ollama
      OLLAMA_URL: http://host.docker.internal:11434
      EMBED_MODEL: embeddinggemma:300m
      VLM_MODEL: gemma4:e2b
      # The measured output dimension of embeddinggemma:300m is 768.
      # EMBED_DIM must always match the actual output dimension of your embed model.
      EMBED_DIM: "768"
      EMBED_DIM_SMALL: "256"
      # ComfyUI
      COMFYUI_URL: http://host.docker.internal:8188
      # WD14 tagger model (required — see INSTALLATION.md Step 2 for download instructions)
      WD14_MODEL_DIR: /mnt/models/wd14
    volumes:
      # Source images: subdirectory name becomes the folder label in the app (:ro required)
      - /your/artworks:/mnt/image/source/artworks:ro
      # Add more source folders as needed:
      # - /your/photos:/mnt/image/source/photos:ro
      # - /your/screenshots:/mnt/image/source/screenshots:ro
      #
      # Output directory for generated images (must be writable)
      - /your/ai_output:/mnt/image/generated
      #
      # ComfyUI workflow directory (:ro)
      - /your/comfy_workflows:/mnt/comfy/workflows:ro
      #
      # WD14 model directory (required — must match WD14_MODEL_DIR above)
      - /your/models/wd14:/mnt/models/wd14:ro
